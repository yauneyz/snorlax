{
  "name": "talysman",
  "desktopName": "com.talysman.app.desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Talysman — a USB-key-gated distraction blocker (Electron UI + privileged native service).",
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:desktop": "cross-env APP_ENV=development pnpm --filter @talysman/desktop dev",
    "dev:down": "supabase stop --workdir apps/web",
    "sync:env": "pnpm --filter @talysman/web sync:env",
    "sync:env:prod": "pnpm --filter @talysman/web sync:env:prod",
    "sync:env:preview": "pnpm --filter @talysman/web sync:env:preview",
    "web:dev": "pnpm --filter @talysman/web dev",
    "web:prod": "pnpm --filter @talysman/web prod",
    "web:build": "pnpm --filter @talysman/web build",
    "web:start": "pnpm --filter @talysman/web start",
    "web:test": "pnpm --filter @talysman/web test",
    "comp": "pnpm --filter @talysman/web comp",
    "web:test:webhook": "pnpm --filter @talysman/web test:webhook",
    "web:test:e2e": "pnpm --filter @talysman/web test:e2e",
    "build:win": "cross-env APP_ENV=production node scripts/build.mjs --target win",
    "build:linux": "cross-env APP_ENV=production node scripts/build.mjs --target linux",
    "build:mac": "cross-env APP_ENV=production node scripts/build.mjs --target mac",
    "build:dev": "cross-env APP_ENV=development node scripts/build.mjs --target linux",
    "build:extension": "node scripts/build-extension.mjs && node scripts/audit-extension.mjs",
    "audit:extension": "node scripts/audit-extension.mjs",
    "release:local": "node scripts/release-local.mjs",
    "release:both": "node scripts/release-both-from-linux.mjs",
    "release:upload": "node scripts/upload-release.mjs",
    "release:upload:win": "node scripts/release-win-from-linux.mjs",
    "release:verify": "node scripts/upload-release.mjs --verify-only",
    "release:version": "node scripts/set-version.mjs",
    "release:apt": "node scripts/publish-apt-repo.mjs",
    "infra:release-bucket": "node scripts/configure-release-bucket.mjs",
    "infra:release-iam": "node scripts/configure-release-iam.mjs",
    "release:extension": "node scripts/release-extension.mjs",
    "build:native:win": "node scripts/build-native-win.mjs",
    "build:native:linux": "node scripts/build-native-linux.mjs",
    "build:native:mac": "node scripts/build-native.mjs --target mac",
    "typecheck": "tsc -b && tsc -p apps/desktop/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:electron:e2e": "cross-env APP_ENV=development TALYSMAN_PIPE=talysman-e2e pnpm --filter @talysman/desktop exec electron-vite build --mode development && playwright test tests/electron/e2e --workers=1",
    "test:watch": "vitest",
    "lint": "eslint . && pnpm --filter @talysman/web lint",
    "lint:fix": "eslint . --fix && pnpm --filter @talysman/web lint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iarna/toml": "^2.2.5",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.9.0",
    "cross-env": "^7.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.7",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.0.5",
    "zod": "^3.23.8"
  }
}
