{
  "$comment": "Language-neutral mirror of packages/shared/src/protocol.ts + events.ts. The TypeScript types are the source of truth; this file documents the same contract for the Rust service. Wire format: newline-delimited JSON, one message per line.",
  "protocolVersion": 1,
  "transport": {
    "windows": "named pipe \\\\.\\pipe\\talysman (dev: talysman-dev)"
  },
  "envelopes": {
    "request": { "kind": "request", "id": "number", "method": "string", "params": "object" },
    "responseOk": { "kind": "response", "id": "number", "ok": true, "result": "object" },
    "responseErr": { "kind": "response", "id": "number", "ok": false, "code": "string", "message": "string" },
    "event": { "kind": "event", "event": "string", "payload": "object" }
  },
  "types": {
    "AppRef": {
      "windowsImageName": "string?",
      "linuxProcessName": "string?",
      "macBundleId": "string?",
      "label": "string"
    },
    "Policy": {
      "mode": "blacklist|whitelist|block-all",
      "domains": "string[]",
      "apps": "AppRef[]"
    },
    "Settings": {
      "browserHandshakeEnabled": "boolean"
    },
    "BrowserHealth": {
      "canBlock": "boolean",
      "permissionsOk": "boolean",
      "dnrRulesApplied": "number?"
    }
  },
  "methods": {
    "getState": { "params": null, "result": "ServiceState" },
    "ping": { "params": null, "result": { "version": "string", "protocolVersion": "number" } },
    "getKeyPresence": { "params": null, "result": { "present": "boolean", "keyId": "string?" } },
    "setPolicy": { "params": { "policy": "Policy" }, "result": { "ok": true } },
    "setSchedule": { "params": { "schedule": "Schedule" }, "result": { "ok": true } },
    "setBrowserHandshake": {
      "params": { "enabled": "boolean" },
      "result": { "ok": true },
      "errors": ["KEY_REQUIRED", "LOCKED"],
      "$comment": "Enabling is free; disabling is key-gated exactly like disableFocus."
    },
    "extHeartbeat": {
      "params": { "browserPid": "number", "browser": "string", "profileId": "string?", "extensionVersion": "string?", "lockedActive": "boolean?", "health": "BrowserHealth" },
      "result": { "ok": true },
      "$comment": "Relayed by talysman-natmsg from the extension. Fire-and-forget; feeds the watchdog. browserPid is the host's parent process (the browser instance)."
    },
    "enableFocus": { "params": { "reason": "string?" }, "result": { "ok": true }, "errors": ["NO_PAIRED_KEY"] },
    "disableFocus": { "params": {}, "result": { "ok": true }, "errors": ["KEY_REQUIRED", "LOCKED"] },
    "listRemovableDrives": { "params": null, "result": { "drives": "Drive[]" } },
    "pairKey": { "params": { "driveId": "string", "label": "string" }, "result": { "key": "PairedKey" } },
    "unpairKey": { "params": { "keyId": "string" }, "result": { "ok": true }, "errors": ["KEY_REQUIRED", "LAST_PAIRED_KEY"] },
    "recover": {
      "params": { "code": "string" },
      "result": { "ok": true },
      "errors": ["BAD_RECOVERY_CODE"],
      "$comment": "Privileged out-of-band killswitch — not surfaced in the UI; used by talysman-recover.exe. Bypasses the USB + locked gates when the code matches."
    }
  },
  "events": {
    "keyPresenceChanged": { "present": "boolean", "keyId": "string?" },
    "focusChanged": { "active": "boolean", "source": "user|schedule|boot|recover" },
    "policyChanged": { "policy": "Policy" },
    "scheduleFired": { "windowId": "string", "active": "boolean" },
    "settingsChanged": { "settings": "Settings" },
    "browserWatchdogWarning": { "browser": "string", "pid": "number" },
    "browserWatchdogKilled": { "browser": "string", "pid": "number" }
  },
  "errorCodes": ["KEY_REQUIRED", "NO_PAIRED_KEY", "LAST_PAIRED_KEY", "LOCKED", "BAD_RECOVERY_CODE", "BAD_REQUEST", "INTERNAL"]
}
