# Copy any per-machine overrides you need into `.env.local` (gitignored). This file
# documents every variable the app understands. See snorlax-architecture.md §11.
#
# Precedence (highest wins): .env.local > .env.<mode> > .env
#
# | Var                          | Public? | Used where            |
# |------------------------------|---------|-----------------------|
# | APP_ENV                      | public  | everywhere            |
# | TALYSMAN_PIPE               | public  | main + native service |
# | VITE_SUPABASE_URL            | public  | main + renderer       |
# | VITE_SUPABASE_ANON_KEY       | public  | main + renderer       |
# | VITE_STRIPE_PUBLISHABLE_KEY  | public  | renderer              |
# | VITE_PAYMENT_URL             | public  | renderer              |
# | API_BASE_URL                 | public  | main — Next.js web origin (e.g. https://app.example.com) |
# | UPDATE_FEED_URL              | public  | updater (Ph.4)        |
# | STRIPE_SECRET_KEY            | SECRET  | NEVER in the app — web backend only |

APP_ENV=development
TALYSMAN_PIPE=talysman-dev

VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_PAYMENT_URL=
API_BASE_URL=
UPDATE_FEED_URL=
