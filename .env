# Shared, non-secret defaults (committed). Override per-mode in .env.development /
# .env.production, and per-machine in .env.local (gitignored).
#
# Renderer-exposed vars MUST be prefixed VITE_. Main-process vars are injected via
# electron.vite.config.ts `define`. Everything is validated by config/schema.ts.

APP_ENV=development

# Local IPC pipe base name shared by the Electron main process and the native service.
# (The actual pipe path is derived in packages/shared/src/constants.ts.)
TALYSMAN_PIPE=talysman

# Auth / payments — UNUSED in phases 1-2, present so config validation has shape.
# Fill these in Phase 3. Never put STRIPE_SECRET_KEY here; it lives server-side only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_PAYMENT_URL=
API_BASE_URL=
UPDATE_FEED_URL=
