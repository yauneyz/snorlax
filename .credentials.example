# .credentials — single source of truth for all secrets.
# Copy this file to `.credentials` (gitignored) and fill in real values.
# Then run `pnpm sync:env` to generate .env.local.

# A `mode` (dev | prod) selects which values get written to .env.local:
#   dev  → local Supabase + local vLLM (`pnpm dev`, the default)
#   prod → cloud Supabase + OpenAI    (`pnpm prod`, or `--mode=prod`)
# APP_ENVIRONMENT and the app URL are derived from the mode.

[app]
name     = "Talysman"                 # appears in metadata, emails
url_dev  = "http://localhost:3000"     # public app URL in dev mode
url_prod = "https://talysman.example" # public app URL in prod mode

[supabase.dev]                         # local stack — values from `supabase status`
url             = "http://127.0.0.1:54321"
publishable_key = "sb_publishable_..." # public client key
secret_key      = "sb_secret_..."      # server-only, never exposed to client
project_ref     = "xxxxx"              # for supabase CLI

[supabase.prod]                        # cloud project
url             = "https://xxxxx.supabase.co"
publishable_key = "sb_publishable_..."
secret_key      = "sb_secret_..."
project_ref     = "xxxxx"

[stripe]
mode                    = "test"       # test | live — picks which keys to export
publishable_key_test    = "pk_test_..."
secret_key_test         = "sk_test_..."
webhook_secret_test     = "whsec_..."
publishable_key_live    = "pk_live_..."
secret_key_live         = "sk_live_..."
webhook_secret_live     = "whsec_..."
price_id_monthly        = "price_..."
price_id_yearly         = "price_..."
portal_configuration_id = ""           # optional; empty = use Stripe default

[resend]
api_key = "re_..."
from    = "Talysman <hello@talysman.example>"

[sentry]
dsn        = ""                         # optional; leave empty until Sentry is configured
org        = "my-org"
project    = "my-saas"
auth_token = "sntrys_..."              # used at build for source map upload

[posthog]
key  = "phc_..."
host = "https://us.i.posthog.com"

[google]
ga4_measurement_id          = "G-XXXXXXXXXX"
search_console_verification = ""       # Search Console "meta tag" content
oauth_client_id             = "...apps.googleusercontent.com"
oauth_client_secret         = "GOCSPX-..."

[aws]
region            = "us-east-1"
access_key_id     = "AKIA..."          # release/upload only; prefer a narrow IAM user or CI role
secret_access_key = "..."              # release/upload only; never expose to browser/client code

[extension_hosting]
bucket = "talysman-release-artifacts-prod" # desktop installer downloads
public_s3_base_url = "https://talysman-release-artifacts-prod.s3.us-east-1.amazonaws.com"

[extension_stores]
chrome_url = ""  # fill after Chrome Web Store publication
edge_url = ""    # fill after Microsoft Edge Add-ons publication
firefox_url = "" # fill after Firefox AMO publication

# LLM provider is derived from the mode: dev → local vLLM, prod → openai.
[openai]                               # used in prod mode
api_key       = "sk-..."               # server-only; required for prod mode
default_model = "gpt-5.1"              # used when callers omit `model`
organization  = ""                     # optional; for multi-org accounts
base_url      = ""                     # optional; e.g. Azure or a gateway

[local_llm]                            # used in dev mode
endpoint = "http://127.0.0.1:11434/v1/chat/completions" # vllmserve OpenAI-compatible endpoint
model    = "qwen3-14b-awq"             # vllmserve served model name
api_key  = ""                          # optional; set if VLLM_API_KEY is enabled

[security]
# Generate both with: node -e 'console.log(require("crypto").randomBytes(32).toString("base64"))'
token_encryption_key = "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="  # AES-256-GCM key for `connections.ciphertext`
oauth_state_secret   = "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="  # HMAC key for the OAuth state cookie
